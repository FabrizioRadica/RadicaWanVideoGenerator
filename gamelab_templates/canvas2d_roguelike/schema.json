{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "radicalab://gamelab_templates/canvas2d_roguelike/schema.json",
  "title": "GameLab Canvas2D Rogue-like configuration",
  "type": "object",
  "required": ["title", "tile_size", "map", "player_spawn", "exit", "player"],
  "additionalProperties": false,
  "properties": {
    "template": { "const": "canvas2d_roguelike" },
    "title": { "type": "string", "minLength": 1, "maxLength": 80 },
    "tile_size": { "type": "number", "minimum": 8, "maximum": 128 },
    "theme": {
      "type": "object", "additionalProperties": false,
      "properties": { "wall_color": { "type": "string" }, "floor_color": { "type": "string" },
        "accent_color": { "type": "string" }, "hud_color": { "type": "string" },
        "exit_color": { "type": "string" }, "treasure_color": { "type": "string" } }
    },
    "map": { "type": "array", "minItems": 2, "maxItems": 60, "items": { "type": "string", "minLength": 2, "maxLength": 80 } },
    "player_spawn": { "$ref": "#/definitions/coord" },
    "exit": { "$ref": "#/definitions/coord" },
    "exit_requires_all_treasure": { "type": "boolean" },
    "player": {
      "type": "object", "required": ["max_hp", "attack"], "additionalProperties": false,
      "properties": { "max_hp": { "type": "number", "exclusiveMinimum": 0, "maximum": 9999 },
        "attack": { "type": "number", "exclusiveMinimum": 0, "maximum": 9999 }, "color": { "type": "string" } }
    },
    "treasure": {
      "type": "array", "maxItems": 200,
      "items": { "type": "object", "required": ["col", "row"], "additionalProperties": false,
        "properties": { "col": { "type": "number" }, "row": { "type": "number" }, "value": { "type": "number", "minimum": 0, "maximum": 100000 } } }
    },
    "potions": {
      "type": "array", "maxItems": 50,
      "items": { "type": "object", "required": ["col", "row", "heal"], "additionalProperties": false,
        "properties": { "col": { "type": "number" }, "row": { "type": "number" }, "heal": { "type": "number", "exclusiveMinimum": 0, "maximum": 9999 } } }
    },
    "keys": {
      "type": "array", "maxItems": 20,
      "items": { "type": "object", "required": ["id", "col", "row"], "additionalProperties": false,
        "properties": { "id": { "type": "string", "pattern": "^[a-z0-9_]{1,40}$" }, "col": { "type": "number" }, "row": { "type": "number" }, "color": { "type": "string" } } }
    },
    "doors": {
      "type": "array", "maxItems": 40,
      "items": { "type": "object", "required": ["col", "row"], "additionalProperties": false,
        "properties": { "key_id": { "type": "string" }, "col": { "type": "number" }, "row": { "type": "number" }, "color": { "type": "string" } } }
    },
    "enemies": {
      "type": "array", "maxItems": 60,
      "items": {
        "type": "object", "required": ["col", "row", "hp", "damage"], "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9_]{1,40}$" }, "name": { "type": "string", "maxLength": 40 },
          "col": { "type": "number" }, "row": { "type": "number" },
          "hp": { "type": "number", "exclusiveMinimum": 0, "maximum": 9999 },
          "damage": { "type": "number", "exclusiveMinimum": 0, "maximum": 9999 },
          "score": { "type": "number", "minimum": 0, "maximum": 100000 },
          "behavior": { "enum": ["wander", "chase"] },
          "sight": { "type": "number", "minimum": 1, "maximum": 40 }, "color": { "type": "string" }
        }
      }
    },
    "assets": {
      "type": "object", "additionalProperties": false,
      "properties": {
        "base_path": { "type": "string", "pattern": "^(?!/)(?!.*\\.\\.).*$" },
        "sprites": { "type": "object", "description": "Keys: player, enemy_<id>. Relative paths only; missing sprites fall back to procedural drawings.",
          "additionalProperties": { "type": "string", "pattern": "^(?!/)(?!.*\\.\\.).*$" } }
      }
    }
  },
  "definitions": {
    "coord": { "type": "object", "required": ["col", "row"], "additionalProperties": false,
      "properties": { "col": { "type": "number", "minimum": 0 }, "row": { "type": "number", "minimum": 0 } } }
  }
}
