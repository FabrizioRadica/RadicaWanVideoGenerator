{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "radicalab://gamelab_templates/canvas2d_endless_topdown/schema.json",
  "title": "GameLab Canvas2D Endless Top-down configuration",
  "type": "object",
  "required": ["title", "canvas", "player", "scroll", "obstacles", "spawn", "lives"],
  "additionalProperties": false,
  "properties": {
    "template": { "const": "canvas2d_endless_topdown" },
    "title": { "type": "string", "minLength": 1, "maxLength": 80 },
    "canvas": {
      "type": "object", "required": ["width", "height"], "additionalProperties": false,
      "properties": { "width": { "type": "number", "minimum": 160, "maximum": 1920 }, "height": { "type": "number", "minimum": 160, "maximum": 1920 } }
    },
    "theme": {
      "type": "object", "additionalProperties": false,
      "properties": { "background_color": { "type": "string" }, "line_color": { "type": "string" },
        "accent_color": { "type": "string" }, "hud_color": { "type": "string" } }
    },
    "player": {
      "type": "object", "required": ["width", "height", "speed"], "additionalProperties": false,
      "properties": {
        "width": { "type": "number", "exclusiveMinimum": 0, "maximum": 400 },
        "height": { "type": "number", "exclusiveMinimum": 0, "maximum": 400 },
        "speed": { "type": "number", "exclusiveMinimum": 0, "maximum": 2000 },
        "hitbox_scale": { "type": "number", "exclusiveMinimum": 0, "maximum": 1 }, "color": { "type": "string" }
      }
    },
    "scroll": {
      "type": "object", "required": ["speed"], "additionalProperties": false,
      "properties": { "speed": { "type": "number", "exclusiveMinimum": 0, "maximum": 2000 } }
    },
    "obstacles": {
      "type": "array", "minItems": 1, "maxItems": 30,
      "items": {
        "type": "object", "required": ["id", "width", "height"], "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9_]{1,40}$" },
          "width": { "type": "number", "exclusiveMinimum": 0, "maximum": 400 },
          "height": { "type": "number", "exclusiveMinimum": 0, "maximum": 400 },
          "speed_bonus": { "type": "number", "minimum": 0, "maximum": 2000 }, "color": { "type": "string" }
        }
      }
    },
    "spawn": {
      "type": "object", "required": ["interval"], "additionalProperties": false,
      "properties": { "interval": { "type": "number", "exclusiveMinimum": 0, "maximum": 60 },
        "min_interval": { "type": "number", "exclusiveMinimum": 0, "maximum": 60 } }
    },
    "pickups": {
      "type": "array", "maxItems": 20,
      "items": {
        "type": "object", "required": ["id", "size"], "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9_]{1,40}$" },
          "size": { "type": "number", "exclusiveMinimum": 0, "maximum": 200 },
          "effect": { "enum": ["score", "extra_life"] },
          "score": { "type": "number", "minimum": 0, "maximum": 100000 },
          "spawn_interval": { "type": "number", "exclusiveMinimum": 0, "maximum": 120 }, "color": { "type": "string" }
        }
      }
    },
    "lives": { "type": "number", "minimum": 1, "maximum": 99 },
    "score": {
      "type": "object", "additionalProperties": false,
      "properties": { "distance_per_second": { "type": "number", "minimum": 0, "maximum": 100000 } }
    },
    "difficulty": {
      "type": "object", "additionalProperties": false,
      "properties": { "ramp": { "type": "number", "minimum": 0, "maximum": 5 }, "max_ramp": { "type": "number", "exclusiveMinimum": 0, "maximum": 20 } }
    },
    "assets": {
      "type": "object", "additionalProperties": false,
      "properties": {
        "base_path": { "type": "string", "pattern": "^(?!/)(?!.*\\.\\.).*$" },
        "sprites": { "type": "object", "description": "Keys: player, obstacle_<id>, pickup_<id>. Relative paths only; missing sprites fall back to procedural drawings.",
          "additionalProperties": { "type": "string", "pattern": "^(?!/)(?!.*\\.\\.).*$" } }
      }
    }
  }
}
