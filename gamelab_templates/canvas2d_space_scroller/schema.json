{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "radicalab://gamelab_templates/canvas2d_space_scroller/schema.json",
  "title": "GameLab Canvas2D Space Scroller configuration",
  "type": "object",
  "required": ["title", "canvas", "tile_size", "map", "player_spawn", "exit", "ship", "lives"],
  "additionalProperties": false,
  "properties": {
    "template": { "const": "canvas2d_space_scroller" },
    "title": { "type": "string", "minLength": 1, "maxLength": 80 },
    "canvas": {
      "type": "object", "required": ["width", "height"], "additionalProperties": false,
      "properties": { "width": { "type": "number", "minimum": 160, "maximum": 1920 }, "height": { "type": "number", "minimum": 160, "maximum": 1920 } }
    },
    "tile_size": { "type": "number", "minimum": 8, "maximum": 128 },
    "hazard_char": { "type": "string", "minLength": 1, "maxLength": 1 },
    "theme": {
      "type": "object", "additionalProperties": false,
      "properties": {
        "space_color": { "type": "string" }, "wall_color": { "type": "string" }, "wall_edge_color": { "type": "string" },
        "hazard_color": { "type": "string" }, "accent_color": { "type": "string" }, "hud_color": { "type": "string" },
        "exit_color": { "type": "string" }, "collectible_color": { "type": "string" }
      }
    },
    "map": { "type": "array", "minItems": 2, "maxItems": 120, "items": { "type": "string", "minLength": 2, "maxLength": 400 } },
    "player_spawn": { "$ref": "#/definitions/coord" },
    "exit": { "$ref": "#/definitions/coord" },
    "exit_requires_all_collectibles": { "type": "boolean" },
    "collectibles": { "type": "array", "maxItems": 400, "items": { "$ref": "#/definitions/coord" } },
    "ship": {
      "type": "object", "required": ["width", "height", "thrust", "max_speed"], "additionalProperties": false,
      "properties": {
        "width": { "type": "number", "exclusiveMinimum": 0, "maximum": 400 },
        "height": { "type": "number", "exclusiveMinimum": 0, "maximum": 400 },
        "thrust": { "type": "number", "exclusiveMinimum": 0, "maximum": 20000 },
        "max_speed": { "type": "number", "exclusiveMinimum": 0, "maximum": 5000 },
        "damping": { "type": "number", "minimum": 0, "maximum": 10 },
        "hitbox_scale": { "type": "number", "exclusiveMinimum": 0, "maximum": 1 },
        "color": { "type": "string" }
      }
    },
    "parallax": {
      "type": "array", "maxItems": 8,
      "items": {
        "type": "object", "required": ["type"], "additionalProperties": false,
        "properties": {
          "type": { "enum": ["stars", "color"] },
          "speed": { "type": "number", "minimum": 0, "maximum": 5 },
          "density": { "type": "number", "minimum": 0, "maximum": 500 },
          "size": { "type": "number", "exclusiveMinimum": 0, "maximum": 20 },
          "alpha": { "type": "number", "minimum": 0, "maximum": 1 },
          "color": { "type": "string" }
        }
      }
    },
    "lives": { "type": "number", "minimum": 1, "maximum": 99 },
    "score": {
      "type": "object", "additionalProperties": false,
      "properties": { "collectible": { "type": "number", "minimum": 0, "maximum": 100000 } }
    },
    "assets": {
      "type": "object", "additionalProperties": false,
      "properties": {
        "base_path": { "type": "string", "pattern": "^(?!/)(?!.*\\.\\.).*$" },
        "sprites": { "type": "object", "description": "Keys: ship, collectible. Relative paths only; missing sprites fall back to procedural drawings.",
          "additionalProperties": { "type": "string", "pattern": "^(?!/)(?!.*\\.\\.).*$" } }
      }
    }
  },
  "definitions": {
    "coord": { "type": "object", "required": ["col", "row"], "additionalProperties": false,
      "properties": { "col": { "type": "number", "minimum": 0 }, "row": { "type": "number", "minimum": 0 } } }
  }
}
