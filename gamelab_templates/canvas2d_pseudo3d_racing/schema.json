{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "radicalab://gamelab_templates/canvas2d_pseudo3d_racing/schema.json",
  "title": "GameLab Canvas2D Pseudo-3D Racing configuration",
  "type": "object",
  "required": ["title", "canvas", "road", "car", "track"],
  "additionalProperties": false,
  "properties": {
    "template": { "const": "canvas2d_pseudo3d_racing" },
    "title": { "type": "string", "minLength": 1, "maxLength": 80 },
    "canvas": {
      "type": "object", "required": ["width", "height"], "additionalProperties": false,
      "properties": { "width": { "type": "number", "minimum": 160, "maximum": 1920 }, "height": { "type": "number", "minimum": 160, "maximum": 1920 } }
    },
    "theme": {
      "type": "object", "additionalProperties": false,
      "properties": {
        "sky_color": { "type": "string" }, "grass_light": { "type": "string" }, "grass_dark": { "type": "string" },
        "rumble_light": { "type": "string" }, "rumble_dark": { "type": "string" }, "road_light": { "type": "string" },
        "road_dark": { "type": "string" }, "lane_marker": { "type": "string" }, "accent_color": { "type": "string" },
        "hud_color": { "type": "string" }, "traffic_color": { "type": "string" }
      }
    },
    "road": {
      "type": "object", "required": ["segment_length", "road_width"], "additionalProperties": false,
      "properties": {
        "segment_length": { "type": "number", "exclusiveMinimum": 0, "maximum": 2000 },
        "rumble_segments": { "type": "number", "exclusiveMinimum": 0, "maximum": 50 },
        "road_width": { "type": "number", "exclusiveMinimum": 0, "maximum": 20000 },
        "lanes": { "type": "number", "minimum": 1, "maximum": 8 },
        "draw_distance": { "type": "number", "minimum": 30, "maximum": 600 },
        "fov": { "type": "number", "exclusiveMinimum": 10, "exclusiveMaximum": 170 },
        "camera_height": { "type": "number", "exclusiveMinimum": 0, "maximum": 20000 }
      }
    },
    "car": {
      "type": "object", "required": ["max_speed", "accel"], "additionalProperties": false,
      "properties": {
        "max_speed": { "type": "number", "exclusiveMinimum": 0, "maximum": 100000 },
        "accel": { "type": "number", "exclusiveMinimum": 0, "maximum": 100000 },
        "brake": { "type": "number", "exclusiveMinimum": 0, "maximum": 200000 },
        "decel": { "type": "number", "exclusiveMinimum": 0, "maximum": 100000 },
        "off_road_decel": { "type": "number", "exclusiveMinimum": 0, "maximum": 200000 },
        "off_road_limit": { "type": "number", "exclusiveMinimum": 0, "maximum": 100000 },
        "centrifugal": { "type": "number", "minimum": 0, "maximum": 5 },
        "steer": { "type": "number", "exclusiveMinimum": 0, "maximum": 20 },
        "color": { "type": "string" }
      }
    },
    "track": {
      "type": "array", "minItems": 1, "maxItems": 200,
      "items": {
        "type": "object", "required": ["length"], "additionalProperties": false,
        "properties": {
          "length": { "type": "number", "minimum": 1, "maximum": 2000 },
          "curve": { "type": "number", "minimum": -20, "maximum": 20 },
          "hill": { "type": "number", "minimum": -20000, "maximum": 20000 }
        }
      }
    },
    "laps": { "type": "number", "minimum": 1, "maximum": 99 },
    "traffic": {
      "type": "object", "additionalProperties": false,
      "properties": {
        "count": { "type": "number", "minimum": 0, "maximum": 60 },
        "speed_factor": { "type": "number", "minimum": 0, "exclusiveMaximum": 1 }
      }
    },
    "assets": {
      "type": "object", "additionalProperties": false,
      "properties": {
        "base_path": { "type": "string", "pattern": "^(?!/)(?!.*\\.\\.).*$" },
        "sprites": { "type": "object", "description": "Keys: car, traffic. Relative paths only; missing sprites fall back to procedural drawings.",
          "additionalProperties": { "type": "string", "pattern": "^(?!/)(?!.*\\.\\.).*$" } }
      }
    }
  }
}
